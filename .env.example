# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=scamwatchxlm-backend
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
API_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://scamwatch:scamwatch@localhost:5432/scamwatchxlm?schema=public

# ---------------------------------------------------------------------------
# Redis (cache, BullMQ queues, rate limiting)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
API_KEY_HEADER=x-api-key
BCRYPT_SALT_ROUNDS=12

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Stellar / Horizon
# ---------------------------------------------------------------------------
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
HORIZON_STREAM_RETRY_MS=5000
HORIZON_POLL_INTERVAL_MS=10000

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URLS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@scamwatchxlm.dev
NOTIFICATIONS_MIN_SEVERITY=high

# ---------------------------------------------------------------------------
# Workers / Jobs
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY=5
RISK_RECALC_CRON=*/15 * * * *
ALERT_CLEANUP_CRON=0 3 * * *
STATS_GENERATION_CRON=*/10 * * * *
ALERT_RETENTION_DAYS=90
